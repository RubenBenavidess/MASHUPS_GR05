@page "/admin/clientes"
@using ec.edu.monster.TicketClient.State
@inject AuthState AuthState
@using ClienteService
@inject ClienteServiceClient ClienteService
@using ec.edu.monster.TicketClient.Utils

<h3 style="text-transform: uppercase;">Administración de Clientes (TicketPremium)</h3>
<p style="color: rgba(245,240,232,0.6); font-size: 0.9rem;">
    Esta pantalla permite gestionar los clientes propios del sistema TicketPremium.
</p>

<!-- Tabs -->
<ul class="nav nav-tabs" style="margin-top: 1.5rem; border-bottom: 2px solid var(--color-gold);">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "listar" ? "active" : "")" style="cursor: pointer; background-color: @(activeTab == "listar" ? "var(--color-gold)" : "transparent"); color: @(activeTab == "listar" ? "black" : "white"); font-weight: bold;" @onclick='() => SetActiveTab("listar")'>Ver Clientes</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "registrar" ? "active" : "")" style="cursor: pointer; background-color: @(activeTab == "registrar" ? "var(--color-gold)" : "transparent"); color: @(activeTab == "registrar" ? "black" : "white"); font-weight: bold;" @onclick='() => SetActiveTab("registrar")'>@(isEditing ? "Editar Cliente" : "Registrar Cliente")</a>
    </li>
</ul>

<div class="card" style="margin-top: 1.5rem;">
    <div class="card-body">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="background: rgba(211,47,47,0.15); border: 1px solid rgba(211,47,47,0.3); border-radius: 8px; padding: 0.8rem; margin-bottom: 1rem;">
                <span style="font-size: 0.85rem; color: var(--color-referee); display: block;">
                    @errorMessage
                </span>
            </div>
        }

        @if (activeTab == "listar")
        {
            <h4>Clientes Registrados</h4>
            @if (clientes == null)
            {
                <p><em>Cargando...</em></p>
            }
            else
            {
                <table class="table table-dark table-hover" style="margin-top: 1rem;">
                    <thead>
                        <tr>
                            <th style="color: var(--color-gold);">Cédula</th>
                            <th style="color: var(--color-gold);">Nombre</th>
                            <th style="color: var(--color-gold);">Apellido</th>
                            <th style="color: var(--color-gold);">Género</th>
                            <th style="color: var(--color-gold);">Teléfono</th>
                            <th style="color: var(--color-gold); text-align: center;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cli in clientes)
                        {
                            <tr>
                                <td>@cli.Cedula</td>
                                <td>@cli.Nombre</td>
                                <td>@cli.Apellido</td>
                                <td>@cli.Genero</td>
                                <td>@cli.Telefono</td>
                                <td style="text-align: center; display: flex; gap: 0.5rem; justify-content: center;">
                                    <button class="btn btn-sm btn-warning" @onclick="() => EditarCliente(cli)" title="Editar Cliente">✏️</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => EliminarCliente(cli.Cedula)" title="Eliminar Cliente">🗑️</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
        else if (activeTab == "registrar")
        {
            <h4>@(isEditing ? "Editar Cliente" : "Crear Nuevo Cliente")</h4>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Cédula:</label>
                    <input @bind="nuevoCliente.Cedula" maxlength="10" class="form-control" disabled="@isEditing" placeholder="Ej. 1712345678" />
                </div>
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Email:</label>
                    <input type="email" @bind="nuevoCliente.Email" class="form-control" placeholder="Ej. correo@ejemplo.com" />
                </div>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Nombre:</label>
                    <input @bind="nuevoCliente.Nombre" class="form-control" placeholder="Ej. Juan" />
                </div>
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Apellido:</label>
                    <input @bind="nuevoCliente.Apellido" class="form-control" placeholder="Ej. Pérez" />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Fecha de Nacimiento:</label>
                    <input type="date" @bind="nuevoCliente.FechaNacimiento" class="form-control" />
                </div>
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Género:</label>
                    <select @bind="nuevoCliente.Genero" class="form-control">
                        <option value="">Seleccione...</option>
                        <option value="MASCULINO">MASCULINO</option>
                        <option value="FEMENINO">FEMENINO</option>
                    </select>
                </div>
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Teléfono:</label>
                    <input @bind="nuevoCliente.Telefono" maxlength="10" class="form-control" placeholder="Ej. 0991234567" />
                </div>
            </div>
            
            <div style="display: flex; gap: 1rem;">
                <button class="btn btn-primary" @onclick="GuardarCliente" style="flex: 1; padding: 0.8rem; font-weight: bold;">
                    @(isEditing ? "Actualizar Cliente" : "Registrar Cliente")
                </button>
                @if (isEditing)
                {
                    <button class="btn btn-secondary" @onclick="CancelarEdicion" style="padding: 0.8rem; font-weight: bold;">
                        Cancelar
                    </button>
                }
            </div>
        }
    </div>
</div>

@code {
    private string activeTab = "listar";
    private List<ClienteDto> clientes;
    private ClienteDto nuevoCliente = new ClienteDto { FechaNacimiento = DateTime.Now.AddYears(-20) };
    private bool isEditing = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
        errorMessage = "";
        if (tab == "registrar" && !isEditing)
        {
            nuevoCliente = new ClienteDto { FechaNacimiento = DateTime.Now.AddYears(-20) };
        }
        else if (tab == "listar")
        {
            CancelarEdicion();
        }
    }

    private async Task CargarClientes()
    {
        var result = await ClienteService.ListarClientesAsync(AuthState.Token);
        clientes = result.ToList();
    }

    private async Task GuardarCliente()
    {
        errorMessage = "";
        if (string.IsNullOrWhiteSpace(nuevoCliente.Email))
        {
            errorMessage = "El email es obligatorio.";
            return;
        }

        if (!new System.ComponentModel.DataAnnotations.EmailAddressAttribute().IsValid(nuevoCliente.Email))
        {
            errorMessage = "El formato del correo electrónico no es válido.";
            return;
        }

        if (!CedulaValidator.EsValida(nuevoCliente.Cedula, out var errorCedula))
        {
            errorMessage = errorCedula;
            return;
        }

        if (string.IsNullOrWhiteSpace(nuevoCliente.Telefono) || nuevoCliente.Telefono.Length > 10 || !nuevoCliente.Telefono.All(char.IsDigit))
        {
            errorMessage = "El teléfono debe contener máximo 10 dígitos numéricos.";
            return;
        }

        try
        {
            if (isEditing)
            {
                await ClienteService.ActualizarClienteAsync(AuthState.Token, nuevoCliente);
            }
            else
            {
                await ClienteService.CrearClienteAsync(AuthState.Token, nuevoCliente);
            }
            
            nuevoCliente = new ClienteDto { FechaNacimiento = DateTime.Now.AddYears(-20) };
            isEditing = false;
            await CargarClientes();
            SetActiveTab("listar");
        }
        catch (Exception ex)
        {
            errorMessage = "Error al guardar cliente. Verifique que la cédula/email no estén duplicados y vuelva a intentar.";
        }
    }

    private void EditarCliente(ClienteDto cli)
    {
        nuevoCliente = new ClienteDto
        {
            Cedula = cli.Cedula,
            Nombre = cli.Nombre,
            Apellido = cli.Apellido,
            FechaNacimiento = cli.FechaNacimiento,
            Genero = cli.Genero,
            Telefono = cli.Telefono,
            Email = cli.Email
        };
        isEditing = true;
        errorMessage = "";
        SetActiveTab("registrar");
    }

    private async Task EliminarCliente(string cedula)
    {
        try
        {
            await ClienteService.EliminarClienteAsync(AuthState.Token, cedula);
            await CargarClientes();
        }
        catch
        {
            errorMessage = "Error al eliminar el cliente. Es posible que tenga registros asociados.";
        }
    }

    private void CancelarEdicion()
    {
        nuevoCliente = new ClienteDto { FechaNacimiento = DateTime.Now.AddYears(-20) };
        isEditing = false;
        errorMessage = "";
    }
}
