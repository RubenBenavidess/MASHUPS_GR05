@inherits LayoutComponentBase
@inject NavigationManager Nav
@using ec.edu.monster.TicketClient.State
@inject AuthState AuthState
@inject CarritoState Carrito
@implements IDisposable

<div class="app-shell">
    <header class="top-nav" style="display: flex; justify-content: space-between; align-items: center; padding-right: 1.5rem; padding-left: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); background: var(--color-bg);">
        <div style="display: flex; align-items: center; gap: 2rem;">
            <a href="/" style="text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2"><path d="M15 5v2M15 11v2M15 17v2M5 5h14a2 2 0 0 1 2 2v3a2 2 0 0 0 0 4v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-3a2 2 0 0 0 0-4V7a2 2 0 0 1 2-2z"/></svg>
                <div style="font-family: var(--font-display); font-weight: 800; font-size: 1.2rem; letter-spacing: 0.05em; color: var(--color-white); white-space: nowrap;">
                    TICKET PREMIUM <span style="color: var(--color-gold);">MONSTER</span>
                </div>
            </a>
            <NavMenu />
        </div>
        
        <div class="auth-section">
            @if (AuthState.IsLoggedIn)
            {
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <span style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-gold);">@AuthState.Nombre (@AuthState.Rol)</span>
                    <button class="btn btn-outline" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;" @onclick="CerrarSesion">Cerrar Sesión</button>
                </div>
            }
            else
            {
                <button class="btn btn-primary" style="padding: 0.4rem 1.2rem; font-size: 0.8rem; font-weight: bold;" @onclick="IrALogin">Iniciar Sesión</button>
            }
        </div>
    </header>

    <main class="main-content">
        @Body
    </main>

    <nav class="bottom-nav" aria-label="Mobile navigation">
        <a href="/" class="bottom-nav-item @(IsActive("/") ? "active" : "")">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Inicio</span>
        </a>
        <a href="/partidos" class="bottom-nav-item @(IsActive("/partidos") ? "active" : "")">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
            <span>Partidos</span>
        </a>
        @if (AuthState.IsLoggedIn)
        {
            <a href="/mis-compras" class="bottom-nav-item @(IsActive("/mis-compras") ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
                <span>Mis Compras</span>
            </a>
            <a href="/facturacion" class="bottom-nav-item @(IsActive("/facturacion") ? "active" : "")">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                <span>Carrito</span>
            </a>
        }
    </nav>

    @if (showLogoutModal)
    {
        <div style="position:fixed; top:0; left:0; width:100vw; height:100vh; background:rgba(0,0,0,0.8); z-index:9999; display:flex; justify-content:center; align-items:center;">
            <div class="card animate-in" style="width:90%; max-width:400px; padding:2rem; text-align:center;">
                <h3 style="color:var(--color-white); margin-bottom:1rem;">¿Cerrar Sesión?</h3>
                <p style="color:rgba(245,240,232,0.7); margin-bottom:2rem; font-size:0.9rem;">
                    ¿Estás seguro de que deseas salir de tu cuenta?
                </p>
                <div style="display:flex; gap:1rem; justify-content:center;">
                    <button class="btn btn-outline" style="flex:1;" @onclick="CancelarCerrarSesion">Cancelar</button>
                    <button class="btn btn-primary" style="flex:1; background:var(--color-referee); border-color:var(--color-referee); color:white;" @onclick="ConfirmarCerrarSesion">Sí, salir</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool showLogoutModal = false;

    protected override void OnInitialized()
    {
        AuthState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AuthState.OnChange -= StateHasChanged;
    }

    private void IrALogin()
    {
        Nav.NavigateTo("/login");
    }

    private void CerrarSesion()
    {
        showLogoutModal = true;
    }

    private void CancelarCerrarSesion()
    {
        showLogoutModal = false;
    }

    private void ConfirmarCerrarSesion()
    {
        showLogoutModal = false;
        AuthState.Logout();
        Carrito.VaciarCarrito();
        Nav.NavigateTo("/");
    }

    private bool IsActive(string path)
    {
        var uri = new Uri(Nav.Uri);
        return uri.AbsolutePath.Equals(path, StringComparison.OrdinalIgnoreCase);
    }
}
