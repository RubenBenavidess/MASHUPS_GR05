@page "/seleccion-asientos/{CodigoPartido}"
@using ec.edu.monster.TicketClient.Modelos
@using ec.edu.monster.TicketClient.Servicios
@inject TicketingService TicketCtrl
@inject NavigationManager NavManager
@implements IDisposable

<div class="match-hero">
    <div class="match-hero-teams">
        <span class="match-hero-team">@TicketCtrl.PartidoLocal</span>
        <span class="match-hero-vs">VS</span>
        <span class="match-hero-team">@TicketCtrl.PartidoVisitante</span>
    </div>
    <div class="match-hero-meta">
        <div class="match-hero-venue">@TicketCtrl.EstadioNombre</div>
        <div class="match-hero-date">@TicketCtrl.PartidoFecha.ToString("dd \\de MMMM, yyyy · HH:mm", new System.Globalization.CultureInfo("es-MX"))</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;align-items:start;">

    <div>
        @if (TicketCtrl.LocalidadActivaCodigo == null)
        {
            <div class="stadium-container">
                <svg viewBox="0 0 800 560" class="stadium-svg" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="pitchGrad" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#2E7D32"/>
                            <stop offset="40%" stop-color="#1B5E20"/>
                            <stop offset="100%" stop-color="#144A17"/>
                        </linearGradient>
                        <filter id="ringGlow">
                            <feGaussianBlur stdDeviation="3" result="blur"/>
                            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                        </filter>
                        <radialGradient id="bgRadial" cx="50%" cy="40%" r="60%">
                            <stop offset="0%" stop-color="#142B47"/>
                            <stop offset="100%" stop-color="#0A1628"/>
                        </radialGradient>
                    </defs>

                    <rect x="0" y="0" width="800" height="560" fill="url(#bgRadial)" rx="16"/>

                    <!-- PITCH -->
                    <rect x="160" y="55" width="480" height="300" rx="4" fill="url(#pitchGrad)" stroke="rgba(255,255,255,0.28)" stroke-width="2"/>
                    <line x1="400" y1="55" x2="400" y2="355" stroke="rgba(255,255,255,0.35)" stroke-width="1"/>
                    <circle cx="400" cy="205" r="50" stroke="rgba(255,255,255,0.35)" stroke-width="1" fill="none"/>
                    <circle cx="400" cy="205" r="4" fill="rgba(255,255,255,0.5)"/>
                    <rect x="160" y="135" width="70" height="140" stroke="rgba(255,255,255,0.3)" stroke-width="1" fill="none"/>
                    <rect x="570" y="135" width="70" height="140" stroke="rgba(255,255,255,0.3)" stroke-width="1" fill="none"/>
                    <rect x="160" y="165" width="30" height="80" stroke="rgba(255,255,255,0.25)" stroke-width="1" fill="none"/>
                    <rect x="610" y="165" width="30" height="80" stroke="rgba(255,255,255,0.25)" stroke-width="1" fill="none"/>

                    @{
                        var localidades = TicketCtrl.GetLocalidades();
                        var ringRadii = new[] { (rx: 270, ry: 155), (rx: 310, ry: 185), (rx: 350, ry: 215) };
                        var ringStrokeW = 34;
                        var centerX = 400;
                        var centerY = 210;
                        var labelX = 630;
                        int idx = 0;

                        foreach (var loc in localidades)
                        {
                            var seats = TicketCtrl.GetAsientosDeLocalidad(loc);
                            var total = seats.Count;
                            var disp = seats.Count(s => s.IsAvailable);
                            var ocup = seats.Count(s => s.IsOccupied || s.IsReserved);
                            var ratio = total > 0 ? (double)disp / total : 0;
                            var locInfo = seats.FirstOrDefault();
                            var (rx, ry) = ringRadii[idx];
                            var labelY = centerY - ry / 2;

                            string strokeColor = ratio > 0.5 ? "rgba(46,125,50,0.55)" : ratio > 0.1 ? "rgba(200,169,81,0.5)" : "rgba(211,47,47,0.45)";
                            string bgColor   = ratio > 0.5 ? "rgba(46,125,50,0.08)" : ratio > 0.1 ? "rgba(200,169,81,0.06)" : "rgba(211,47,47,0.06)";

                            <g style="cursor:pointer;" @onclick="() => TicketCtrl.SeleccionarLocalidad(loc)" class="ring-group" role="button">

                                <ellipse cx="@centerX" cy="@centerY" rx="@rx" ry="@ry"
                                         fill="@bgColor" stroke="@strokeColor" stroke-width="@ringStrokeW"
                                         style="transition:all 0.3s ease;"/>

                                <ellipse cx="@centerX" cy="@centerY" rx="@rx" ry="@ry"
                                         fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"
                                         pointer-events="none"/>

                                <line x1="@(centerX + rx - ringStrokeW/2)" y1="@centerY"
                                      x2="@(labelX - 10)" y2="@labelY"
                                      stroke="rgba(200,169,81,0.25)" stroke-width="1"/>

                                <circle cx="@labelX" cy="@labelY" r="5" fill="@strokeColor" pointer-events="none"/>

                                <text x="@(labelX + 16)" y="@(labelY - 6)" class="section-label" style="font-size:16px;font-weight:700;">
                                    @locInfo?.LocalidadDescripcion
                                </text>
                                <text x="@(labelX + 16)" y="@(labelY + 10)" class="section-capacity" style="font-size:11px;">
                                    @disp/@total · desde $@(locInfo?.Price ?? 0)
                                </text>
                                <text x="@(labelX + 16)" y="@(labelY + 24)" class="section-capacity" style="font-size:10px;fill:rgba(245,240,232,0.4);">
                                    @($"{ratio * 100:F0}% libre · Click para ver asientos")
                                </text>
                            </g>
                            idx++;
                        }
                    }

                    <!-- STADIUM TITLE -->
                    <text x="400" y="470" text-anchor="middle" font-family="var(--font-display)" font-size="14" font-weight="700"
                          fill="var(--color-gold)" letter-spacing="0.08em" opacity="0.5">
                        @TicketCtrl.EstadioNombre.ToUpper()
                    </text>

                    <!-- LEGEND -->
                    <g transform="translate(580, 488)">
                        <rect x="0" y="0" width="10" height="10" rx="2" fill="rgba(46,125,50,0.7)"/>
                        <text x="16" y="9" font-family="var(--font-mono)" font-size="9" fill="rgba(245,240,232,0.45)">Disponible</text>
                        <rect x="80" y="0" width="10" height="10" rx="2" fill="rgba(211,47,47,0.5)"/>
                        <text x="96" y="9" font-family="var(--font-mono)" font-size="9" fill="rgba(245,240,232,0.45)">Ocupado</text>
                        <rect x="155" y="0" width="10" height="10" rx="2" fill="rgba(200,169,81,0.7)"/>
                        <text x="171" y="9" font-family="var(--font-mono)" font-size="9" fill="rgba(245,240,232,0.45)">Parcial</text>
                    </g>

                    <!-- COMPASS / SCALE HINT -->
                    <text x="40" y="480" font-family="var(--font-mono)" font-size="8" fill="rgba(245,240,232,0.15)">VISTA AÉREA</text>
                    <text x="40" y="492" font-family="var(--font-mono)" font-size="8" fill="rgba(245,240,232,0.1)">ESCALA APROXIMADA</text>
                </svg>
            </div>
        }
        else
        {
            <div>
                <button class="back-btn" @onclick="() => TicketCtrl.VolverASecciones()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                    Volver al mapa del estadio
                </button>

                <div class="seat-grid-container animate-in" style="margin-top:0.75rem;">
                    <div class="seat-grid-header">
                        <div>
                            <h3 style="margin:0;">@TicketCtrl.LocalidadActivaNombre</h3>
                            <span style="font-family:var(--font-mono);font-size:0.72rem;color:rgba(245,240,232,0.4);">@TicketCtrl.LocalidadActivaCodigo</span>
                        </div>
                        <div class="legend">
                            <div class="legend-item"><span class="legend-dot available"></span> Disponible</div>
                            <div class="legend-item"><span class="legend-dot occupied"></span> Ocupado</div>
                            <div class="legend-item"><span class="legend-dot selected"></span> Seleccionado</div>
                        </div>
                    </div>

                    <div style="text-align:center;margin-bottom:1rem;">
                        <span style="font-family:var(--font-mono);font-size:0.7rem;color:rgba(245,240,232,0.3);">↓ CAMPO DE JUEGO ↓</span>
                    </div>

                    @{
                        var asientosLoc = TicketCtrl.GetAsientosDeLocalidadActiva();
                        var filas = asientosLoc.Select(a => a.Fila).Distinct().OrderBy(f => f).ToList();

                        foreach (var fila in filas)
                        {
                            var seatsInRow = asientosLoc.Where(a => a.Fila == fila).OrderBy(a => a.Numero).ToList();
                            <div class="seat-row">
                                <span class="seat-row-label">@fila</span>
                                @foreach (var seat in seatsInRow)
                                {
                                    var cssClass = seat.Status switch
                                    {
                                        "Disponible" => "seat-available",
                                        "Ocupado" => "seat-occupied",
                                        "Seleccionado" => "seat-selected",
                                        "Reservado" => "seat-reserved",
                                        _ => "seat-available",
                                    };
                                    <div class="seat-cell @cssClass"
                                         @onclick="() => SeleccionarAsiento(seat.Id)"
                                         title="@seat.Id - $@seat.Price - @seat.Status">
                                        @seat.Numero
                                    </div>
                                }
                            </div>
                        }
                    }

                    <div style="text-align:center;margin-top:1rem;">
                        <span style="font-family:var(--font-mono);font-size:0.6rem;color:rgba(245,240,232,0.2);">PASILLO CENTRAL · ACCESO PRINCIPAL</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="cart-panel">
        <h4>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2" style="vertical-align:middle;margin-right:0.4rem;"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            Tus Entradas
            @if (TicketCtrl.Cart.Count > 0)
            {
                <span style="font-family:var(--font-mono);font-size:0.65rem;background:var(--color-gold);color:var(--color-midnight);padding:0.1em 0.5em;border-radius:999px;margin-left:0.5rem;font-weight:700;">@TicketCtrl.Cart.Count</span>
            }
        </h4>

        @if (TicketCtrl.Cart.Count == 0)
        {
            <div style="text-align:center;padding:2rem 1rem;">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" style="margin-bottom:1rem;opacity:0.3;">
                    <rect x="8" y="14" width="32" height="26" rx="3" stroke="#C8A951" stroke-width="1.5"/>
                    <path d="M16 14V10a8 8 0 0 1 16 0v4" stroke="#C8A951" stroke-width="1.5"/>
                    <line x1="24" y1="22" x2="24" y2="32" stroke="#C8A951" stroke-width="1.5"/>
                    <line x1="18" y1="27" x2="30" y2="27" stroke="#C8A951" stroke-width="1.5"/>
                </svg>
                <p style="font-family:var(--font-mono);font-size:0.78rem;color:rgba(245,240,232,0.35);">Selecciona una localidad<br/>y elige tus asientos</p>
            </div>
        }
        else
        {
            <div style="max-height:360px;overflow-y:auto;margin-bottom:0.5rem;">
                @foreach (var item in TicketCtrl.Cart)
                {
                    <div class="cart-item">
                        <div>
                            <div class="cart-item-code">@item.Id</div>
                            <div style="font-size:0.65rem;color:rgba(245,240,232,0.35);">@item.LocalidadDescripcion · Fila @item.Fila</div>
                        </div>
                        <div style="display:flex;align-items:center;gap:0.6rem;">
                            <span class="cart-item-price">$@item.Price.ToString("F0")</span>
                            <button style="background:none;border:none;color:var(--color-referee);cursor:pointer;font-size:1rem;padding:0;line-height:1;"
                                    @onclick="() => SeleccionarAsiento(item.Id)"
                                    title="Quitar">✕</button>
                        </div>
                    </div>
                }
            </div>

            <div class="cart-total">
                <span class="cart-total-label">Total</span>
                <span class="cart-total-amount">$@TicketCtrl.GetTotal().ToString("F0")</span>
            </div>

            <button class="btn btn-primary" style="width:100%;margin-top:1rem;"
                    @onclick="IrAFacturacion">
                Ir a Pagar
            </button>
        }
    </div>
</div>

@code {
    [Parameter]
    public string CodigoPartido { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        TicketCtrl.OnStateChanged += StateHasChanged;
        TicketCtrl.CargarAsientosPorPartido(CodigoPartido);
    }

    private void SeleccionarAsiento(string id)
    {
        TicketCtrl.ToggleSeat(id);
    }

    private void IrAFacturacion()
    {
        if (TicketCtrl.Cart.Count > 0)
        {
            NavManager.NavigateTo("/facturacion");
        }
    }

    public void Dispose()
    {
        TicketCtrl.OnStateChanged -= StateHasChanged;
    }
}
