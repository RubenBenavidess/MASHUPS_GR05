@page "/compra-exitosa"
@inject NavigationManager NavManager

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;padding:2rem;">
    <div class="animate-in" style="margin-bottom:2rem;">
        <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
            <circle cx="50" cy="50" r="45" stroke="#2E7D32" stroke-width="4" stroke-dasharray="283" stroke-dashoffset="283">
                <animate attributeName="stroke-dashoffset" from="283" to="0" dur="0.8s" fill="freeze"/>
            </circle>
            <polyline points="30,50 44,64 70,36" stroke="#C8A951" stroke-width="5" fill="none" stroke-linecap="round" stroke-linejoin="round"
                       stroke-dasharray="70" stroke-dashoffset="70">
                <animate attributeName="stroke-dashoffset" from="70" to="0" dur="0.5s" begin="0.5s" fill="freeze"/>
            </polyline>
        </svg>
    </div>

    <h1 style="color:var(--color-turf);font-size:2.4rem;margin-bottom:0.5rem;" class="animate-in">¡Compra Exitosa!</h1>
    <p style="font-family:var(--font-body);font-size:1.05rem;color:rgba(245,240,232,0.55);margin-bottom:2rem;max-width:480px;line-height:1.6;" class="animate-in">
        Tus boletos han sido reservados. Recibirás un correo con los detalles de tu compra y las instrucciones para el día del partido.
    </p>

    <div class="animate-in" style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
        <button class="btn btn-primary btn-lg" @onclick="() => NavManager.NavigateTo('/partidos')">
            Ver Más Partidos
        </button>
        <button class="btn btn-outline btn-lg" @onclick="() => NavManager.NavigateTo('/')">
            Ir al Inicio
        </button>
    </div>

    <div style="margin-top:3rem;padding:1.5rem;background:var(--color-navy);border-radius:var(--radius-md);border:1px solid rgba(200,169,81,0.12);max-width:400px;width:100%;" class="animate-in">
        <div style="font-family:var(--font-mono);font-size:0.68rem;color:rgba(245,240,232,0.4);margin-bottom:0.5rem;">SÍGUENOS</div>
        <div style="font-family:var(--font-display);font-size:1.1rem;letter-spacing:0.04em;color:var(--color-chalk);">TicketPremium</div>
        <div style="font-family:var(--font-mono);font-size:0.7rem;color:rgba(245,240,232,0.3);">FIFA World Cup 2026 · Boletos Oficiales</div>
    </div>
</div>
