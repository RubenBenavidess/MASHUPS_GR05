@using ec.edu.monster.TicketClient.State
@inject CarritoState Carrito

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">TicketPremium</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Inicio
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="partidos">
                <span class="bi bi-calendar-event-fill-nav-menu" aria-hidden="true"></span> Catálogo Partidos
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="facturacion">
                <span class="bi bi-cart-fill-nav-menu" aria-hidden="true"></span>
                Facturación
                @if (Carrito.AsientosSeleccionados.Count > 0)
                {
                    <span class="badge bg-danger ms-2">@Carrito.AsientosSeleccionados.Count</span>
                }
            </NavLink>
        </div>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        // Esto hace que el numerito rojo del carrito se actualice en el menú en tiempo real
        Carrito.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Carrito.OnChange -= StateHasChanged;
    }
}