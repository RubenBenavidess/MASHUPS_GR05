@page "/seleccion-asientos/{CodigoPartido}"
@using ec.edu.monster.TicketClient.Modelos
@using ec.edu.monster.TicketClient.Servicios
@inject TicketingService TicketCtrl
@inject NavigationManager NavManager
@implements IDisposable

<div class="match-hero">
    <div class="match-hero-teams">
        <img src="@GetFlagUrl(TicketCtrl.PartidoLocal)" alt="@TicketCtrl.PartidoLocal"
             style="width:48px;height:32px;border-radius:4px;object-fit:cover;box-shadow:0 2px 8px rgba(0,0,0,0.4);margin-right:1rem;" />
        <span class="match-hero-team">@TicketCtrl.PartidoLocal</span>
        <span class="match-hero-vs">VS</span>
        <span class="match-hero-team">@TicketCtrl.PartidoVisitante</span>
        <img src="@GetFlagUrl(TicketCtrl.PartidoVisitante)" alt="@TicketCtrl.PartidoVisitante"
             style="width:48px;height:32px;border-radius:4px;object-fit:cover;box-shadow:0 2px 8px rgba(0,0,0,0.4);margin-left:1rem;" />
    </div>
    <div class="match-hero-meta">
        <div class="match-hero-venue">@TicketCtrl.EstadioNombre</div>
        <div class="match-hero-date">@TicketCtrl.PartidoFecha.ToString("dd \\de MMMM, yyyy · HH:mm", new System.Globalization.CultureInfo("es-MX"))</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 320px;gap:1.5rem;align-items:start;">
    <div>
        <div style="background:linear-gradient(145deg,#0d1f3a,#0a1628);border-radius:20px;padding:1rem;box-shadow:0 8px 40px rgba(0,0,0,0.6);">

            <!-- LEYENDA -->
            <div style="display:flex;gap:1.2rem;justify-content:center;margin-bottom:0.8rem;">
                <div style="display:flex;align-items:center;gap:5px;">
                    <div style="width:9px;height:9px;border-radius:2px;background:#43A047;"></div>
                    <span style="font-family:var(--font-mono);font-size:0.62rem;color:rgba(245,240,232,0.5);">Disponible</span>
                </div>
                <div style="display:flex;align-items:center;gap:5px;">
                    <div style="width:9px;height:9px;border-radius:2px;background:#555;"></div>
                    <span style="font-family:var(--font-mono);font-size:0.62rem;color:rgba(245,240,232,0.5);">Ocupado</span>
                </div>
                <div style="display:flex;align-items:center;gap:5px;">
                    <div style="width:9px;height:9px;border-radius:2px;background:#FBC02D;"></div>
                    <span style="font-family:var(--font-mono);font-size:0.62rem;color:rgba(245,240,232,0.5);">Seleccionado</span>
                </div>
            </div>

            <!-- ESTADIO -->
            @{
                var zN  = GetZone("Norte");
                var zS  = GetZone("Sur");
                var zVN = GetZone("VipNorte");
                var zVS = GetZone("VipSur");
                var zL  = GetZone("Lateral");
            }

            <div style="display:grid;grid-template-columns:70px 1fr 70px;grid-template-rows:90px 240px 90px;gap:4px;">

                <!-- Fila 1: esquina vacia | NORTE | esquina vacia -->
                <div></div>
                @if (zN != null)
                {
                    <div class="sz-block @(selectedZone==zN.Codigo?"sz-sel":"")" style="@BlockBg(zN)"
                         @onclick="()=>Toggle(zN.Codigo)">
                        @{ var seatsN = GetSeatGrid(zN.Codigo); }
                        <div style="display:grid;grid-template-columns:repeat(@seatsN.Cols,1fr);grid-template-rows:repeat(@seatsN.Rows,1fr);gap:1px;width:100%;height:100%;">
                            @foreach (var color in seatsN.Colors)
                            {
                                <div style="background:@color;border-radius:1px;"></div>
                            }
                        </div>
                    </div>
                }
                else { <div></div> }
                <div></div>

                <!-- Fila 2: VIP_N | (Lateral L + Cancha + Lateral R) | VIP_S -->
                @if (zVN != null)
                {
                    <div class="sz-block @(selectedZone==zVN.Codigo?"sz-sel":"")" style="@BlockBg(zVN)"
                         @onclick="()=>Toggle(zVN.Codigo)">
                        @{ var seatsVN = GetSeatGridV(zVN.Codigo); }
                        <div style="display:grid;grid-template-columns:repeat(@seatsVN.Cols,1fr);grid-template-rows:repeat(@seatsVN.Rows,1fr);gap:1px;width:100%;height:100%;">
                            @foreach (var color in seatsVN.Colors)
                            {
                                <div style="background:@color;border-radius:1px;"></div>
                            }
                        </div>
                    </div>
                }
                else { <div></div> }

                <!-- Sub-grid central: Lateral Oeste | Cancha | Lateral Este -->
                <div style="display:grid;grid-template-columns:1fr 2.2fr 1fr;gap:4px;height:100%;">
                    @if (zL != null)
                    {
                        <div class="sz-block @(selectedZone=="Lateral_L"?"sz-sel":"")" style="@BlockBg(zL, "Lateral_L")"
                             @onclick='()=>Toggle("Lateral_L")'>
                            @{ var seatsLW = GetSeatGridV(zL.Codigo, "left"); }
                            <div style="display:grid;grid-template-columns:repeat(@seatsLW.Cols,1fr);grid-template-rows:repeat(@seatsLW.Rows,1fr);gap:1px;width:100%;height:100%;">
                                @foreach (var color in seatsLW.Colors)
                                {
                                    <div style="background:@color;border-radius:1px;"></div>
                                }
                            </div>
                        </div>
                    }
                    else { <div></div> }

                    <!-- CANCHA -->
                    <div style="background:linear-gradient(160deg,#1a5c1e,#0f3a11);border-radius:12px;overflow:hidden;box-shadow:inset 0 0 20px rgba(0,0,0,0.5);">
                        <svg viewBox="0 0 300 210" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;">
                            <rect width="300" height="210" fill="#1a5c1e"/>
                            <rect y="0"   width="300" height="26" fill="#1e6622"/>
                            <rect y="52"  width="300" height="26" fill="#1e6622"/>
                            <rect y="104" width="300" height="26" fill="#1e6622"/>
                            <rect y="156" width="300" height="26" fill="#1e6622"/>
                            <rect x="7" y="7" width="286" height="196" rx="3" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="1.8"/>
                            <line x1="150" y1="7" x2="150" y2="203" stroke="rgba(255,255,255,0.6)" stroke-width="1.4"/>
                            <circle cx="150" cy="105" r="34" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1.4"/>
                            <circle cx="150" cy="105" r="2.5" fill="rgba(255,255,255,0.8)"/>
                            <rect x="7" y="60" width="46" height="90" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.4"/>
                            <rect x="7" y="83" width="18" height="44" fill="none" stroke="rgba(255,255,255,0.35)" stroke-width="1.1"/>
                            <rect x="247" y="60" width="46" height="90" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.4"/>
                            <rect x="275" y="83" width="18" height="44" fill="none" stroke="rgba(255,255,255,0.35)" stroke-width="1.1"/>
                            <circle cx="33" cy="105" r="2" fill="rgba(255,255,255,0.65)"/>
                            <circle cx="267" cy="105" r="2" fill="rgba(255,255,255,0.65)"/>
                        </svg>
                    </div>

                    <!-- Tribuna Este (Mitad Derecha) -->
                    @if (zL != null)
                    {
                        <div class="sz-block @(selectedZone=="Lateral_R"?"sz-sel":"")" style="@BlockBg(zL, "Lateral_R")"
                             @onclick='()=>Toggle("Lateral_R")'>
                            @{ var seatsLE = GetSeatGridV(zL.Codigo, "right"); }
                            <div style="display:grid;grid-template-columns:repeat(@seatsLE.Cols,1fr);grid-template-rows:repeat(@seatsLE.Rows,1fr);gap:1px;width:100%;height:100%;">
                                @foreach (var color in seatsLE.Colors)
                                {
                                    <div style="background:@color;border-radius:1px;"></div>
                                }
                            </div>
                        </div>
                    }
                    else { <div></div> }
                </div>

                @if (zVS != null)
                {
                    <div class="sz-block @(selectedZone==zVS.Codigo?"sz-sel":"")" style="@BlockBg(zVS)"
                         @onclick="()=>Toggle(zVS.Codigo)">
                        @{ var seatsVS = GetSeatGridV(zVS.Codigo); }
                        <div style="display:grid;grid-template-columns:repeat(@seatsVS.Cols,1fr);grid-template-rows:repeat(@seatsVS.Rows,1fr);gap:1px;width:100%;height:100%;">
                            @foreach (var color in seatsVS.Colors)
                            {
                                <div style="background:@color;border-radius:1px;"></div>
                            }
                        </div>
                    </div>
                }
                else { <div></div> }

                <!-- Fila 3: esquina vacia | SUR | esquina vacia -->
                <div></div>
                @if (zS != null)
                {
                    <div class="sz-block @(selectedZone==zS.Codigo?"sz-sel":"")" style="@BlockBg(zS)"
                         @onclick="()=>Toggle(zS.Codigo)">
                        @{ var seatsS = GetSeatGrid(zS.Codigo); }
                        <div style="display:grid;grid-template-columns:repeat(@seatsS.Cols,1fr);grid-template-rows:repeat(@seatsS.Rows,1fr);gap:1px;width:100%;height:100%;">
                            @foreach (var color in seatsS.Colors)
                            {
                                <div style="background:@color;border-radius:1px;"></div>
                            }
                        </div>
                    </div>
                }
                else { <div></div> }
                <div></div>
            </div>

            <!-- PANEL EXPANDIDO AL SELECCIONAR ZONA -->
            @if (selectedZone != null)
            {
                string dbCode = selectedZone;
                string sideSuffix = "";
                if (selectedZone == "Lateral_L" || selectedZone == "Lateral_R")
                {
                    var zLat = GetZone("Lateral");
                    if (zLat != null) dbCode = zLat.Codigo;
                    sideSuffix = selectedZone == "Lateral_L" ? "Oeste" : "Este";
                }

                var zi = localidadZones.FirstOrDefault(z => z.Codigo == dbCode);
                var allSeats = TicketCtrl.GetAsientosDeLocalidad(dbCode);

                // Dividir los asientos según la zona clicada
                var seatsForPanelRows = allSeats.GroupBy(s => s.Fila).OrderBy(g => g.Key)
                    .Select(grp => {
                        var sorted = grp.OrderBy(s => s.Numero).ToList();
                        if (selectedZone == "Lateral_L") return sorted.Take(sorted.Count / 2).ToList();
                        if (selectedZone == "Lateral_R") return sorted.Skip(sorted.Count / 2).ToList();
                        return sorted;
                    })
                    .Where(r => r.Any())
                    .ToList();

                int totalDisp = seatsForPanelRows.SelectMany(r => r).Count(s => s.Status == "Disponible");
                string dispName = zi?.Descripcion ?? "Zona";
                if (sideSuffix != "") dispName += $" ({sideSuffix})";

                <div style="margin-top:1rem;background:rgba(255,255,255,0.03);border:1px solid rgba(200,169,81,0.3);border-radius:14px;padding:1.2rem;animation:fadeIn 0.2s ease;">
                    <div style="display:flex;align-items:baseline;gap:1rem;margin-bottom:1rem;flex-wrap:wrap;">
                        <span style="font-family:var(--font-display);font-size:0.9rem;font-weight:700;color:#C8A951;">@dispName</span>
                        <span style="font-family:var(--font-mono);font-size:0.78rem;color:rgba(245,240,232,0.55);">$@zi?.Precio / asiento &nbsp;·&nbsp; @totalDisp disponibles</span>
                    </div>
                    <div style="overflow-x:auto;">
                        @foreach (var rowList in seatsForPanelRows)
                        {
                            var firstSeat = rowList.First();
                            <div style="display:flex;align-items:center;gap:4px;margin-bottom:5px;min-width:max-content;">
                                <span style="font-family:var(--font-mono);font-size:0.6rem;color:rgba(245,240,232,0.3);width:14px;text-align:right;flex-shrink:0;">@firstSeat.Fila</span>
                                @foreach (var seat in rowList)
                                {
                                    string bg = seat.Status switch
                                    {
                                        "Disponible"   => "#388E3C",
                                        "Seleccionado" => "#F9A825",
                                        _              => "#424242"
                                    };
                                    bool ok = seat.Status is "Disponible" or "Seleccionado";
                                    <div title="Fila @seat.Fila · Asiento @seat.Numero · $@seat.Price"
                                         style="width:26px;height:26px;border-radius:5px;background:@bg;cursor:@(ok?"pointer":"not-allowed");display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-size:0.55rem;color:rgba(255,255,255,0.85);font-weight:700;flex-shrink:0;@(!ok?"opacity:0.3;":"box-shadow:0 2px 5px rgba(0,0,0,0.4);")"
                                         @onclick="()=>{ if(ok) SeleccionarAsiento(seat.Id); }">
                                        @seat.Numero
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- CARRITO -->
    <div class="cart-panel">
        <h4>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2" style="vertical-align:middle;margin-right:0.4rem;">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            Tus Entradas
            @if (TicketCtrl.Cart.Count > 0)
            {
                <span style="font-family:var(--font-mono);font-size:0.65rem;background:var(--color-gold);color:var(--color-midnight);padding:0.1em 0.5em;border-radius:999px;margin-left:0.5rem;font-weight:700;">@TicketCtrl.Cart.Count</span>
            }
        </h4>
        @if (TicketCtrl.Cart.Count == 0)
        {
            <div style="text-align:center;padding:2rem 1rem;">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" style="margin-bottom:1rem;opacity:0.3;">
                    <rect x="8" y="14" width="32" height="26" rx="3" stroke="#C8A951" stroke-width="1.5"/>
                    <path d="M16 14V10a8 8 0 0 1 16 0v4" stroke="#C8A951" stroke-width="1.5"/>
                    <line x1="24" y1="22" x2="24" y2="32" stroke="#C8A951" stroke-width="1.5"/>
                    <line x1="18" y1="27" x2="30" y2="27" stroke="#C8A951" stroke-width="1.5"/>
                </svg>
                <p style="font-family:var(--font-mono);font-size:0.78rem;color:rgba(245,240,232,0.35);">Haz clic en una zona<br/>y elige tu asiento</p>
            </div>
        }
        else
        {
            <div style="max-height:400px;overflow-y:auto;margin-bottom:0.5rem;">
                @foreach (var item in TicketCtrl.Cart)
                {
                    <div class="cart-item">
                        <div>
                            <div class="cart-item-code">@item.Id</div>
                            <div style="font-size:0.65rem;color:rgba(245,240,232,0.35);">@item.LocalidadDescripcion · Fila @item.Fila</div>
                        </div>
                        <div style="display:flex;align-items:center;gap:0.6rem;">
                            <span class="cart-item-price">$@item.Price.ToString("F0")</span>
                            <button style="background:none;border:none;color:var(--color-referee);cursor:pointer;font-size:1rem;padding:0;"
                                    @onclick="()=>SeleccionarAsiento(item.Id)">&#x2715;</button>
                        </div>
                    </div>
                }
            </div>
            <div class="cart-total">
                <span class="cart-total-label">Total</span>
                <span class="cart-total-amount">$@TicketCtrl.GetTotal().ToString("F0")</span>
            </div>
            <button class="btn btn-primary" style="width:100%;margin-top:1rem;" @onclick="IrAFacturacion">Ir a Pagar</button>
        }
    </div>
</div>

<style>
    .sz-block {
        border-radius: 10px;
        cursor: pointer;
        transition: filter 0.15s, transform 0.12s;
        overflow: hidden;
        padding: 4px;
        box-sizing: border-box;
    }
    .sz-block:hover { filter: brightness(1.2); transform: scale(1.015); }
    .sz-sel { border-color: #C8A951 !important; box-shadow: 0 0 0 2px rgba(200,169,81,0.5); }
    @@keyframes fadeIn {
        from { opacity:0; transform:translateY(8px); }
        to   { opacity:1; transform:translateY(0); }
    }
</style>

@code {
    [Parameter] public string CodigoPartido { get; set; } = string.Empty;
    private string? selectedZone = null;

    public class LocalidadZone
    {
        public string Codigo { get; set; } = "";
        public string Descripcion { get; set; } = "";
        public decimal Precio { get; set; }
        public int Total { get; set; }
        public int Disponibles { get; set; }
        public string Posicion { get; set; } = "";
    }

    public class SeatGridData
    {
        public int Rows { get; set; }
        public int Cols { get; set; }
        public List<string> Colors { get; set; } = new();
    }

    private List<LocalidadZone> localidadZones = new();

    protected override async Task OnInitializedAsync()
    {
        TicketCtrl.OnStateChanged += StateHasChanged;
        await TicketCtrl.CargarAsientosPorPartidoAsync(CodigoPartido);
        MapearZonas();
    }

    private void MapearZonas()
    {
        localidadZones.Clear();
        var sorted = TicketCtrl.GetLocalidades()
            .Select(cod => {
                var s = TicketCtrl.GetAsientosDeLocalidad(cod);
                var f = s.FirstOrDefault();
                return new { Codigo = cod, Desc = f?.LocalidadDescripcion ?? cod,
                             Precio = f?.Price ?? 0m, Total = s.Count,
                             Disp = s.Count(x => x.Status == "Disponible") };
            })
            .OrderByDescending(x => x.Precio).ToList();

        var pos = new[] { "VipNorte", "VipSur", "Lateral", "Norte", "Sur" };
        for (int i = 0; i < sorted.Count && i < pos.Length; i++)
        {
            localidadZones.Add(new LocalidadZone
            {
                Codigo = sorted[i].Codigo, Descripcion = sorted[i].Desc,
                Precio = sorted[i].Precio, Total = sorted[i].Total,
                Disponibles = sorted[i].Disp, Posicion = pos[i]
            });
        }
    }

    private LocalidadZone? GetZone(string p) => localidadZones.FirstOrDefault(z => z.Posicion == p);

    private string BlockBg(LocalidadZone z, string pseudoCode = null)
    {
        string bg = z.Posicion switch {
            "VipNorte" or "VipSur" => "linear-gradient(135deg,rgba(200,169,81,0.15),rgba(200,169,81,0.04))",
            "Lateral" => "linear-gradient(135deg,rgba(21,101,192,0.25),rgba(21,101,192,0.06))",
            _ => "linear-gradient(135deg,rgba(46,125,50,0.25),rgba(46,125,50,0.06))"
        };
        string target = pseudoCode ?? z.Codigo;
        string brd = selectedZone == target ? "#C8A951" : "rgba(255,255,255,0.06)";
        return $"background:{bg};border:2px solid {brd};";
    }

    private string SeatColor(string status) => status switch
    {
        "Disponible" => "#43A047",
        "Seleccionado" => "#FBC02D",
        _ => "#4a4a4a"
    };

    private SeatGridData GetSeatGrid(string codigo)
    {
        var seats = TicketCtrl.GetAsientosDeLocalidad(codigo);
        if (!seats.Any()) return new SeatGridData { Rows = 1, Cols = 1, Colors = new List<string> { "transparent" } };

        var rows = seats.GroupBy(s => s.Fila).OrderBy(g => g.Key).ToList();
        int numCols = rows.Max(r => r.Count());
        int numRows = rows.Count;
        var colors = new List<string>();

        foreach (var row in rows)
        {
            var sorted = row.OrderBy(s => s.Numero).ToList();
            for (int c = 0; c < numCols; c++)
                colors.Add(c < sorted.Count ? SeatColor(sorted[c].Status) : "transparent");
        }

        return new SeatGridData { Rows = numRows, Cols = numCols, Colors = colors };
    }

    private SeatGridData GetSeatGridV(string codigo, string half = "all")
    {
        var seats = TicketCtrl.GetAsientosDeLocalidad(codigo);
        if (!seats.Any()) return new SeatGridData { Rows = 1, Cols = 1, Colors = new List<string> { "transparent" } };

        var dataRows = seats.GroupBy(s => s.Fila).OrderBy(g => g.Key).ToList();
        
        // Invertir filas para la mitad izquierda, así la fila A (frente) queda pegada a la cancha
        if (half == "left") dataRows.Reverse();

        var matrixRows = new List<List<string>>();
        int maxVisRows = 0;

        foreach (var row in dataRows)
        {
            var sorted = row.OrderBy(s => s.Numero).ToList();
            int count = sorted.Count;
            if (half == "left") sorted = sorted.Take(count / 2).ToList();
            else if (half == "right") sorted = sorted.Skip(count / 2).ToList();
            
            if (sorted.Count > maxVisRows) maxVisRows = sorted.Count;
            
            matrixRows.Add(sorted.Select(s => SeatColor(s.Status)).ToList());
        }

        int visCols = matrixRows.Count;
        int visRows = maxVisRows;

        var matrix = new string[visRows, visCols];
        for (int c = 0; c < visCols; c++)
        {
            var colColors = matrixRows[c];
            for (int r = 0; r < visRows; r++)
                matrix[r, c] = r < colColors.Count ? colColors[r] : "transparent";
        }

        var colors = new List<string>();
        for (int r = 0; r < visRows; r++)
            for (int c = 0; c < visCols; c++)
                colors.Add(matrix[r, c]);

        return new SeatGridData { Rows = visRows, Cols = visCols, Colors = colors };
    }

    private void Toggle(string cod) => selectedZone = selectedZone == cod ? null : cod;
    private void SeleccionarAsiento(string id) => TicketCtrl.ToggleSeat(id);
    private void IrAFacturacion() { if (TicketCtrl.Cart.Count > 0) NavManager.NavigateTo("/facturacion"); }

    private static string GetFlagUrl(string equipo)
    {
        if (string.IsNullOrWhiteSpace(equipo)) return "https://flagcdn.com/w80/un.png";
        var d = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            {"México","mx"},{"Estados Unidos","us"},{"EE. UU.","us"},{"Canadá","ca"},
            {"Argentina","ar"},{"Brasil","br"},{"Uruguay","uy"},{"Colombia","co"},{"Ecuador","ec"},
            {"Paraguay","py"},{"Francia","fr"},{"Alemania","de"},{"España","es"},{"Inglaterra","gb-eng"},
            {"Países Bajos","nl"},{"Portugal","pt"},{"Bélgica","be"},{"Croacia","hr"},{"Italia","it"},
            {"Suiza","ch"},{"Suecia","se"},{"Noruega","no"},{"Escocia","gb-sct"},{"Bosnia y Herzegovina","ba"},
            {"Chequia","cz"},{"Bosnia y Herz.","ba"},{"Gales","gb-wls"},{"Austria","at"},
            {"Marruecos","ma"},{"Senegal","sn"},{"Egipto","eg"},{"Argelia","dz"},{"Costa de Marfil","ci"},
            {"Túnez","tn"},{"Sudáfrica","za"},{"Ghana","gh"},{"RD Congo","cd"},{"Cabo Verde","cv"},
            {"Japón","jp"},{"Corea del Sur","kr"},{"Arabia Saudita","sa"},{"Irán","ir"},{"Australia","au"},
            {"Uzbekistán","uz"},{"Irak","iq"},{"Jordania","jo"},{"Qatar","qa"},{"Türkiye","tr"},
            {"Nueva Zelanda","nz"},{"Haití","ht"},{"Panamá","pa"},{"Curazao","cw"}
        };
        if (d.TryGetValue(equipo.Trim(), out var c)) return $"https://flagcdn.com/w80/{c}.png";
        return "https://flagcdn.com/w80/un.png";
    }

    public void Dispose() => TicketCtrl.OnStateChanged -= StateHasChanged;
}
