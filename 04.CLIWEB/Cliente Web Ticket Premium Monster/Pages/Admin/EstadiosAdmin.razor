@page "/admin/estadios"
@using EstadioService
@using ec.edu.monster.TicketClient.State
@inject EstadioServiceClient EstadioService
@inject AuthState AuthState

<h3 style="text-transform: uppercase;">Administración de Estadios</h3>
<p style="color: rgba(245,240,232,0.6); font-size: 0.9rem;">
    Esta pantalla permite gestionar los estadios para los partidos.
</p>

<!-- Tabs -->
<ul class="nav nav-tabs" style="margin-top: 1.5rem; border-bottom: 2px solid var(--color-gold);">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "listar" ? "active" : "")" style="cursor: pointer; background-color: @(activeTab == "listar" ? "var(--color-gold)" : "transparent"); color: @(activeTab == "listar" ? "black" : "white"); font-weight: bold;" @onclick='() => SetActiveTab("listar")'>Ver Estadios</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "registrar" ? "active" : "")" style="cursor: pointer; background-color: @(activeTab == "registrar" ? "var(--color-gold)" : "transparent"); color: @(activeTab == "registrar" ? "black" : "white"); font-weight: bold;" @onclick='() => SetActiveTab("registrar")'>@(isEditing ? "Editar Estadio" : "Registrar Estadio")</a>
    </li>
</ul>

<div class="card" style="margin-top: 1.5rem;">
    <div class="card-body">
        @if (activeTab == "listar")
        {
            <h4>Estadios Registrados</h4>
            @if (isLoading)
            {
                <p><em>Cargando...</em></p>
            }
            else
            {
                <table class="table table-dark table-hover" style="margin-top: 1rem;">
                    <thead>
                        <tr>
                            <th style="color: var(--color-gold);">Código</th>
                            <th style="color: var(--color-gold);">Nombre</th>
                            <th style="color: var(--color-gold);">Ciudad</th>
                            <th style="color: var(--color-gold);">Capacidad</th>
                            <th style="color: var(--color-gold);">País</th>
                            <th style="color: var(--color-gold); text-align: center;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var estadio in estadios)
                        {
                            <tr>
                                <td>@estadio.Codigo</td>
                                <td>@estadio.Nombre</td>
                                <td>@estadio.Ciudad</td>
                                <td>@estadio.CapacidadTotal</td>
                                <td>@estadio.PaisCodigo</td>
                                <td style="text-align: center; display: flex; gap: 0.5rem; justify-content: center;">
                                    <button class="btn btn-sm btn-warning" @onclick="() => EditarEstadio(estadio)" title="Editar Estadio">✏️</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => EliminarEstadio(estadio.Codigo)" title="Eliminar Estadio">🗑️</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
        else if (activeTab == "registrar")
        {
            <h4>@(isEditing ? "Editar Estadio" : "Crear Nuevo Estadio")</h4>
            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 1rem; margin-bottom: 1rem; margin-top: 1rem;">
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Código:</label>
                    <input @bind="currentEstadio.Codigo" class="form-control" disabled="@isEditing" placeholder="Ej. EST-01" />
                </div>
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Nombre:</label>
                    <input @bind="currentEstadio.Nombre" class="form-control" placeholder="Ej. Estadio Azteca" />
                </div>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Ciudad:</label>
                    <input @bind="currentEstadio.Ciudad" class="form-control" placeholder="Ej. Ciudad de México" />
                </div>
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Capacidad Total:</label>
                    <input type="number" @bind="currentEstadio.CapacidadTotal" class="form-control" />
                </div>
                <div class="form-group">
                    <label style="display: block; font-size: 0.85rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Código País:</label>
                    <input @bind="currentEstadio.PaisCodigo" class="form-control" placeholder="Ej. MEX" />
                </div>
            </div>
            
            <div style="display: flex; gap: 1rem;">
                <button class="btn btn-primary" @onclick="GuardarEstadio" style="flex: 1; padding: 0.8rem; font-weight: bold;">
                    Guardar Estadio
                </button>
                @if (isEditing)
                {
                    <button class="btn btn-secondary" @onclick="CancelarEdicion" style="padding: 0.8rem; font-weight: bold;">
                        Cancelar
                    </button>
                }
            </div>
        }
    </div>
</div>

@code {
    private string activeTab = "listar";
    private List<EstadioDto> estadios = new();
    private EstadioDto currentEstadio = new();
    private bool isEditing = false;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarEstadios();
        isLoading = false;
    }

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
        if (tab == "registrar" && !isEditing)
        {
            currentEstadio = new();
        }
        else if (tab == "listar")
        {
            CancelarEdicion();
        }
    }

    private async Task CargarEstadios()
    {
        var result = await EstadioService.ListarEstadiosAsync(AuthState.Token);
        estadios = result.ToList();
    }

    private async Task GuardarEstadio()
    {
        if (isEditing)
        {
            await EstadioService.ActualizarEstadioAsync(AuthState.Token, currentEstadio);
        }
        else
        {
            await EstadioService.CrearEstadioAsync(AuthState.Token, currentEstadio);
        }
        await CargarEstadios();
        CancelarEdicion();
        SetActiveTab("listar");
    }

    private void EditarEstadio(EstadioDto estadio)
    {
        currentEstadio = new EstadioDto
        {
            Codigo = estadio.Codigo,
            Nombre = estadio.Nombre,
            Ciudad = estadio.Ciudad,
            CapacidadTotal = estadio.CapacidadTotal,
            PaisCodigo = estadio.PaisCodigo
        };
        isEditing = true;
        SetActiveTab("registrar");
    }

    private async Task EliminarEstadio(string codigo)
    {
        await EstadioService.EliminarEstadioAsync(AuthState.Token, codigo);
        await CargarEstadios();
    }

    private void CancelarEdicion()
    {
        currentEstadio = new();
        isEditing = false;
    }
}
