    private static string GetFlagUrl(string equipo)
    {
        var dict = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            {"Mexico", "mx"}, {"Estados Unidos", "us"}, {"EE. UU.", "us"}, {"Canada", "ca"},
            {"Argentina", "ar"}, {"Brasil", "br"}, {"Uruguay", "uy"}, {"Colombia", "co"}, {"Ecuador", "ec"},
            {"Paraguay", "py"}, {"Francia", "fr"}, {"Alemania", "de"}, {"Espana", "es"}, {"Inglaterra", "gb-eng"},
            {"Paises Bajos", "nl"}, {"Portugal", "pt"}, {"Belgica", "be"}, {"Croacia", "hr"}, {"Italia", "it"},
            {"Suiza", "ch"}, {"Suecia", "se"}, {"Noruega", "no"}, {"Escocia", "gb-sct"}, {"Bosnia y Herzegovina", "ba"},
            {"Chequia", "cz"}, {"Bosnia y Herz.", "ba"}, {"Gales", "gb-wls"}, {"Austria", "at"},
            {"Marruecos", "ma"}, {"Senegal", "sn"}, {"Egipto", "eg"}, {"Argelia", "dz"}, {"Costa de Marfil", "ci"},
            {"Tunez", "tn"}, {"Sudafrica", "za"}, {"Ghana", "gh"}, {"RD Congo", "cd"}, {"Cabo Verde", "cv"},
            {"Japon", "jp"}, {"Corea del Sur", "kr"}, {"Arabia Saudita", "sa"}, {"Iran", "ir"}, {"Australia", "au"},
            {"Uzbekistan", "uz"}, {"Irak", "iq"}, {"Jordania", "jo"}, {"Qatar", "qa"}, {"Turkiye", "tr"},
            {"Nueva Zelanda", "nz"}, {"Haiti", "ht"}, {"Panama", "pa"}, {"Curazao", "cw"},
            {"Costa Rica", "cr"}, {"Honduras", "hn"}, {"Jamaica", "jm"}, {"Peru", "pe"}, {"Chile", "cl"},
            {"Bolivia", "bo"}, {"Venezuela", "ve"}, {"Dinamarca", "dk"}, {"Polonia", "pl"}, {"Rumania", "ro"},
            {"Serbia", "rs"}, {"Grecia", "gr"}, {"Hungria", "hu"}, {"Eslovaquia", "sk"}, {"Eslovenia", "si"},
            {"Finlandia", "fi"}, {"Islandia", "is"}, {"Irlanda", "ie"}, {"Camerun", "cm"}, {"Nigeria", "ng"}
        };

        string equipoNorm = new string(equipo.Normalize(System.Text.NormalizationForm.FormD)
            .Where(c => System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c) != System.Globalization.UnicodeCategory.NonSpacingMark)
            .ToArray());

        if (dict.TryGetValue(equipoNorm.Trim(), out var code))
            return $"https://flagcdn.com/w80/{code}.png";

        return "https://flagcdn.com/w80/un.png";
    }
