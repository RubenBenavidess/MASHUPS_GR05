@page "/crear-cuenta"
@using ec.edu.monster.TicketClient.State
@using AuthService
@inject AuthServiceClient AuthService
@inject AuthState AuthState
@inject NavigationManager NavManager

<div class="login-container" style="max-width: 500px; padding-bottom: 2rem;">
    <div class="login-header">
        <div style="width: 200px; height: 200px; border-radius: 50%; overflow: hidden; border: 2px solid var(--color-gold); margin-bottom: 1rem; box-shadow: 0 4px 15px rgba(200, 169, 81, 0.3);">
            <img src="/images/sulli_analitico.jpeg" alt="Sullivan Login" style="width: 100%; height: 100%; object-fit: cover; object-position: center;" />
        </div>
        <h2 style="color: var(--color-white); font-weight: 700; margin-bottom: 0.5rem; letter-spacing: 0.02em;">
            Crear Cuenta
        </h2>
        <p style="color: rgba(245,240,232,0.6); font-size: 0.85rem; font-family: var(--font-body);">
            Únete y compra tus entradas para el Mundial
        </p>
    </div>

    <div class="card login-card">
        <div class="card-body" style="padding: 2rem;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div>
                    <label style="display: block; font-size: 0.8rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Cédula *</label>
                    <input @bind="cedula" type="text" placeholder="17..." class="form-control" style="width: 100%; background: rgba(10,22,40,0.4); color: #F5F0E8; border: 1px solid rgba(200,169,81,0.2); padding: 0.75rem; border-radius: 8px;" />
                </div>
                <div>
                    <label style="display: block; font-size: 0.8rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Género</label>
                    <select @bind="genero" class="form-control" style="width: 100%; background: rgba(10,22,40,0.4); color: #F5F0E8; border: 1px solid rgba(200,169,81,0.2); padding: 0.75rem; border-radius: 8px;">
                        <option value="MASCULINO">Masculino</option>
                        <option value="FEMENINO">Femenino</option>
                    </select>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div>
                    <label style="display: block; font-size: 0.8rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Nombres *</label>
                    <input @bind="nombre" type="text" placeholder="Juan" class="form-control" style="width: 100%; background: rgba(10,22,40,0.4); color: #F5F0E8; border: 1px solid rgba(200,169,81,0.2); padding: 0.75rem; border-radius: 8px;" />
                </div>
                <div>
                    <label style="display: block; font-size: 0.8rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Apellidos *</label>
                    <input @bind="apellido" type="text" placeholder="Pérez" class="form-control" style="width: 100%; background: rgba(10,22,40,0.4); color: #F5F0E8; border: 1px solid rgba(200,169,81,0.2); padding: 0.75rem; border-radius: 8px;" />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div>
                    <label style="display: block; font-size: 0.8rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Correo Electrónico *</label>
                    <input @bind="email" type="email" placeholder="ej. usuario@correo.com" class="form-control" style="width: 100%; background: rgba(10,22,40,0.4); color: #F5F0E8; border: 1px solid rgba(200,169,81,0.2); padding: 0.75rem; border-radius: 8px;" />
                </div>
                <div>
                    <label style="display: block; font-size: 0.8rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Teléfono</label>
                    <input @bind="telefono" type="text" placeholder="09..." class="form-control" style="width: 100%; background: rgba(10,22,40,0.4); color: #F5F0E8; border: 1px solid rgba(200,169,81,0.2); padding: 0.75rem; border-radius: 8px;" />
                </div>
            </div>

            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-size: 0.8rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Fecha de Nacimiento</label>
                <input @bind="fechaNacimiento" type="date" class="form-control" style="width: 100%; background: rgba(10,22,40,0.4); color: #F5F0E8; border: 1px solid rgba(200,169,81,0.2); padding: 0.75rem; border-radius: 8px;" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                <div>
                    <label style="display: block; font-size: 0.8rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Contraseña *</label>
                    <input @bind="password" type="password" placeholder="Mínimo 6 caracteres" class="form-control" style="width: 100%; background: rgba(10,22,40,0.4); color: #F5F0E8; border: 1px solid rgba(200,169,81,0.2); padding: 0.75rem; border-radius: 8px;" />
                </div>
                <div>
                    <label style="display: block; font-size: 0.8rem; color: rgba(245,240,232,0.6); margin-bottom: 0.4rem;">Confirmar Contraseña *</label>
                    <input @bind="confirmarPassword" type="password" placeholder="Confirma tu contraseña" class="form-control" style="width: 100%; background: rgba(10,22,40,0.4); color: #F5F0E8; border: 1px solid rgba(200,169,81,0.2); padding: 0.75rem; border-radius: 8px;" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="background: rgba(211,47,47,0.15); border: 1px solid rgba(211,47,47,0.3); border-radius: 8px; padding: 0.8rem 1rem; margin-bottom: 1.2rem; text-align: center;">
                    <span style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-referee);">@errorMessage</span>
                </div>
            }

            <button class="btn btn-primary" style="width: 100%; padding: 0.8rem; border-radius: 12px; font-weight: 700; font-size: 0.95rem; margin-bottom: 0.5rem;" @onclick="ProcesarRegistro" disabled="@isLoading">
                @(isLoading ? "Cargando..." : "CREAR CUENTA")
            </button>

            <div style="text-align:center; margin-top:1rem; font-size:0.85rem; color:rgba(245,240,232,0.6);">
                ¿Ya tienes una cuenta? <a href="/login" style="color:var(--color-gold); font-weight:bold; text-decoration:none;">Inicia sesión</a>
            </div>
        </div>
    </div>
</div>

<style>
    .login-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding-top: 3rem;
        width: 100%;
        margin: 0 auto;
    }

    .login-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .icon-circle {
        background: rgba(245,240,232,0.1);
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .login-card {
        width: 100%;
        border-radius: 16px;
        background: var(--color-card-bg);
        border: 1px solid var(--color-card-border);
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }
</style>

@code {
    private string cedula = "";
    private string nombre = "";
    private string apellido = "";
    private string email = "";
    private string telefono = "";
    private string genero = "MASCULINO";
    private DateTime fechaNacimiento = new DateTime(2000, 1, 1);
    private string password = "";
    private string confirmarPassword = "";
    
    private string errorMessage = "";
    private bool isLoading = false;

    private async Task ProcesarRegistro()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(cedula) || string.IsNullOrWhiteSpace(nombre) || 
            string.IsNullOrWhiteSpace(apellido) || string.IsNullOrWhiteSpace(email) || 
            string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Cédula, Nombres, Apellidos, Correo y Contraseña son obligatorios.";
            return;
        }

        if (password != confirmarPassword)
        {
            errorMessage = "Las contraseñas no coinciden.";
            return;
        }

        if (password.Length < 6)
        {
            errorMessage = "La contraseña debe tener al menos 6 caracteres.";
            return;
        }

        isLoading = true;

        try
        {
            var request = new RegistroRequest
            {
                Cedula = cedula.Trim(),
                Nombre = nombre.Trim(),
                Apellido = apellido.Trim(),
                Email = email.Trim(),
                Telefono = telefono?.Trim() ?? "",
                Genero = genero,
                FechaNacimiento = fechaNacimiento,
                Password = password
            };

            var response = await AuthService.RegistroAsync(request);

            if (response.Exitoso)
            {
                AuthState.Login(response.SessionToken, response.Cedula, response.Nombre, response.Rol);
                NavManager.NavigateTo("/");
            }
            else
            {
                errorMessage = response.Mensaje;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}