@using ec.edu.monster.TicketClient.State
@inject CarritoState Carrito
@inject AuthState AuthState
@implements IDisposable

<div class="nav-inner">
    <nav class="nav-links" aria-label="Main navigation">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Inicio
        </NavLink>

        <NavLink class="nav-link" href="partidos">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
            Partidos
        </NavLink>

        @if (AuthState.IsLoggedIn)
        {
            <NavLink class="nav-link" href="mis-compras">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
                Mis compras
            </NavLink>
            <NavLink class="nav-link cart-link" href="facturacion">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                Carrito
                @if (Carrito.AsientosSeleccionados.Count > 0)
                {
                    <span class="cart-badge">@Carrito.AsientosSeleccionados.Count</span>
                }
            </NavLink>
        }
        
        @if (AuthState.IsAdmin)
        {
            <div class="css-dropdown">
                <button class="nav-link dropdown-toggle-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    Administración
                </button>
                <div class="css-dropdown-menu">
                    <NavLink class="dropdown-item" href="admin/paises">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><circle cx="12" cy="12" r="10"/><path d="M2 12h20 M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        Países
                    </NavLink>
                    <NavLink class="dropdown-item" href="admin/estadios">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                        Estadios
                    </NavLink>
                    <NavLink class="dropdown-item" href="admin/localidades">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M21 9H3 M21 15H3 M9 3v18 M15 3v18"/></svg>
                        Localidades
                    </NavLink>
                    <NavLink class="dropdown-item" href="admin/partidos">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
                        Partidos
                    </NavLink>
                    <NavLink class="dropdown-item" href="admin/resumen-ventas">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        Resumen Ventas
                    </NavLink>
                    <div class="css-dropdown-divider"></div>
                    <NavLink class="dropdown-item" href="admin/clientes">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Clientes TP
                    </NavLink>
                    <NavLink class="dropdown-item" href="admin/clientes-banco">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                        Clientes Banco
                    </NavLink>
                </div>
            </div>
        }
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        Carrito.OnChange += StateHasChanged;
        AuthState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Carrito.OnChange -= StateHasChanged;
        AuthState.OnChange -= StateHasChanged;
    }
}
